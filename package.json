{
  "name": "wechat-tui",
  "version": "0.2.1",
  "description": "A terminal client for WeChat.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BigLiao/wechat-tui.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "wechat-tui": "dist/index.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.75.5",
    "chalk": "^5.4.1",
    "pino": "^9.5.0",
    "qrcode-terminal": "^0.12.0",
    "wechat4u": "^0.7.12",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
